{
  "version": 1,
  "patterns": [
    {
      "type": "movie",
      "patterns": [
        "(?:watch|see|check out|stream|rewatch)\\s+['\"]([^'\"]+)['\"]",
        "(?:the (?:movie|film|documentary))\\s+['\"]([^'\"]+)['\"]",
        "['\"]([^'\"]+)['\"]\\s*\\((\\d{4})\\)",
        "(?:starring|directed by|from)\\s+(.+?)(?:\\s+in\\s+)?['\"]([^'\"]+)['\"]"
      ]
    },
    {
      "type": "tvShow",
      "patterns": [
        "(?:the show|series|season \\d+ of)\\s+['\"]([^'\"]+)['\"]",
        "(?:on|streaming on)\\s+(?:Netflix|Hulu|HBO|Disney|Amazon|Apple TV)\\b"
      ]
    },
    {
      "type": "app",
      "patterns": [
        "(?:download|get|try|use|open)\\s+(?:the\\s+)?([A-Z]\\w+(?:\\s+\\w+){0,2})\\s+(?:app|from the App Store)",
        "(?:available on|download from)\\s+the App Store"
      ]
    },
    {
      "type": "song",
      "patterns": [
        "(?:song|track|single|playing)\\s+['\"]([^'\"]+)['\"](?:\\s+by\\s+(.+?))?",
        "(?:listen to|listening to|heard)\\s+['\"]([^'\"]+)['\"]"
      ]
    },
    {
      "type": "book",
      "patterns": [
        "(?:book|read|reading|wrote|written by)\\s+['\"]([^'\"]+)['\"]",
        "(?:the book)\\s+['\"]([^'\"]+)['\"]\\s+by\\s+(.+)"
      ]
    },
    {
      "type": "youtube",
      "patterns": [
        "(?:on YouTube|YouTube channel|YouTube video|check out on YouTube)",
        "(?:linked in the description|link in bio|link below)"
      ]
    },
    {
      "type": "sportingEvent",
      "patterns": [
        "(?:Super Bowl|World Series|NBA Finals|World Cup|Olympics|March Madness)",
        "(?:game \\d+|playoff|championship|final four)"
      ]
    }
  ]
}
